
model Post {
  id String @id @default(uuid())
  title String
  content String
  thumbnail String
  isFeatured Boolean
  status Status @default(PUBLISHED)
  tags Status[]
  views Int
  authorId String
  author User @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comment Comment[] 
}

enum Status {
  PUBLISHED
  PENDING
  REJECTED
}